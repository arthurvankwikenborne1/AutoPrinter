{
  "name": "outlook-pdf-print-agent",
  "version": "1.0.0",
  "description": "Outlook Add-in om PDF en Word bijlagen af te drukken vanuit ongelezen mails",
  "scripts": {
    "start": "office-addin-dev-certs install --machine && npx http-server . -p 3000 --ssl --cert %USERPROFILE%/.office-addin-dev-certs/localhost.crt --key %USERPROFILE%/.office-addin-dev-certs/localhost.key -c-1",
    "start-http": "npx http-server . -p 3000 -c-1",
    "validate": "office-addin-manifest validate manifest/manifest.xml"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.10.0"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "office-addin-dev-certs": "^2.0.7",
    "office-addin-manifest": "^2.1.3"
  }
}